        "toEmail": "={{ $env.REPORT_TO_EMAIL }}",
        "subject": "=[AI-Ops Watchdog] Weekly Report — {{ $('Compute Weekly Report').first().json.report_date }} | Health Score: {{ $('Compute Weekly Report').first().json.metrics.health_score }}/100",
        "options": {}
      },
      "id": "78f7c68a-5c88-4db6-a9b8-2d3c95803908",
